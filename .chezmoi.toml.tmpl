# 更新後は chezmoi init

[data]
username = "{{ .chezmoi.username }}"
hostname = "{{ .chezmoi.hostname }}"
system = "{{ .chezmoi.os }}-{{ .chezmoi.arch }}"

[edit]
command = "nvim"

[git]
autoPush = false
autoCommit = true
commitMessageTemplate = 'chore(chezmoi): {{ "{{" }} .chezmoi.command {{ "}}" }}{{ "{{" }} if .chezmoi.args {{ "}}" }} {{ "{{" }} join " " (slice .chezmoi.args 2) | replaceAllRegex .chezmoi.homeDir "~" {{ "}}" }}{{ "{{" }} end {{ "}}" }}'
